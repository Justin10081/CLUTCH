# Supabase (required for user accounts - get from supabase.com)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Groq AI (required for syllabus parsing + Clutch Mode - get free key at console.groq.com)
VITE_GROQ_API_KEY=your_groq_api_key

# The app works without these — it runs in demo mode with localStorage
